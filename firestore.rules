rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    match /rooms/{roomCode} {
      // Anyone can read rooms to fetch game state
      allow read: if true;
      
      // All writes to rooms must be done via Admin SDK (Cloud Functions)
      allow write: if false;

      match /players/{playerId} {
        // Anyone can read the player list
        allow read: if true;
        
        // Creation is handled by createRoom and joinRoom callables
        allow create: if false;
        
        // Players can update only cosmetic/heartbeat/reaction fields on their own document.
        // Critical game fields like score, role, host status, and rejoin identifiers are locked to server writes.
        allow update: if isAuthenticated() 
                      && resource.data.authUid == request.auth.uid
                      && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['role', 'totalScore', 'timesFooled', 'playersDeceived', 'isHost', 'joinedAt', 'hasRerolled', 'authUid', 'id']);
        
        // Deletions and host handoffs are handled server-side by handleDisconnect callable
        allow delete: if false;
      }
    }
  }
}
